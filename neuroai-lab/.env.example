# ──────────────────────────────────────────
#  NeuroAI Lab — Environment Variables
# ──────────────────────────────────────────
#  Copy this file to .env.local and fill in
#  the values. Never commit .env.local.
# ──────────────────────────────────────────

# Base URL (used for canonical URLs and OG metadata)
NEXT_PUBLIC_SITE_URL=https://neuroai-lab.vercel.app

# Resend API key — used by app/api/contact/route.ts
# Get yours at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email address to receive contact form messages
CONTACT_TO_EMAIL=lazaro@neuroai-lab.org
